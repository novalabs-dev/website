---
import Layout from './Layout.astro';

interface RelatedPost {
  title: string;
  slug: string;
}

interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
  ogImage?: string;
  keywords?: string[];
  relatedPosts?: RelatedPost[];
}

const { title, description, date, readTime, ogImage, keywords = [], relatedPosts = [] } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const articleUrl = `https://nova-labs.dev${Astro.url.pathname}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": date,
      "url": articleUrl,
      ...(keywords.length > 0 && { "keywords": keywords.join(", ") }),
      "author": {
        "@type": "Organization",
        "name": "Nova Labs",
        "url": "https://nova-labs.dev"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Nova Labs",
        "url": "https://nova-labs.dev"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": articleUrl
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://nova-labs.dev/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://nova-labs.dev/blog/" },
        { "@type": "ListItem", "position": 3, "name": title, "item": articleUrl }
      ]
    }
  ]
};
---

<Layout
  title={`${title} | Nova Labs Blog`}
  description={description}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-40 transition-all duration-300" id="navbar">
    <div class="section-container flex items-center justify-between py-4">
      <a href="/" class="text-xl font-bold tracking-tight">
        <span class="text-primary-light">Nova</span><span class="text-text-dim">Labs</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/skills" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Skills</a>
        <a href="/blog" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Blog</a>
        <a href="/#pricing" class="btn-primary !py-2.5 !px-5 !text-sm">
          Get the playbook
        </a>
      </div>
    </div>
  </nav>

  <!-- ARTICLE -->
  <article class="pt-32 pb-24">
    <div class="section-container max-w-3xl">
      <!-- Header -->
      <div class="mb-12">
        <a href="/blog" class="text-text-dim hover:text-text-muted text-sm transition-colors inline-flex items-center gap-1 mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to blog
        </a>
        <h1 class="text-4xl md:text-5xl font-black leading-tight mb-4 tracking-tight">{title}</h1>
        <div class="flex items-center gap-4 text-text-dim text-sm">
          <span>{date}</span>
          <span class="w-1 h-1 bg-text-dim rounded-full"></span>
          <span>{readTime}</span>
        </div>
      </div>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="mt-16">
          <h3 class="text-xl font-bold mb-6">You might also like</h3>
          <div class="grid gap-4">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class="glass-card p-5 block hover:border-primary/30 transition-all duration-300 group">
                <span class="font-semibold group-hover:text-primary-light transition-colors">{post.title}</span>
                <span class="text-primary-light text-sm ml-2 inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA: Email capture -->
      <div class="mt-16 glass-card p-8 md:p-10 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-accent via-primary to-accent"></div>
        <h3 class="text-2xl font-bold mb-3">Want to build your own AI OS?</h3>
        <p class="text-text-muted mb-6">The AI OS Blueprint gives you the complete system: 53-page playbook, working skills, and a clonable repo. Starting at $47.</p>

        <a href="/#pricing" class="btn-primary !py-3.5 !px-8 inline-block">
          Get the Blueprint
        </a>

        <p class="mt-4 text-text-dim text-xs">30-day money-back guarantee. No subscription.</p>
      </div>
    </div>
  </article>

  <!-- FOOTER -->
  <footer class="py-12 border-t border-surface-lighter/30">
    <div class="section-container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="text-text-dim text-sm">
            <span class="text-primary-light font-semibold">Nova Labs</span> - An AI-first business experiment by AckNova Automations
          </p>
          <p class="text-text-dim/60 text-xs mt-1">
            &copy; 2026 Nova Labs. All rights reserved.
          </p>
        </div>
        <div class="flex items-center gap-6 text-sm text-text-dim flex-wrap justify-center">
          <a href="/" class="hover:text-text transition-colors">Playbook</a>
          <a href="/skills" class="hover:text-text transition-colors">Skills</a>
          <a href="/blog" class="hover:text-text transition-colors">Blog</a>
          <a href="/terms" class="hover:text-text transition-colors">Terms</a>
          <a href="/refund-policy" class="hover:text-text transition-colors">Refund Policy</a>
          <a href="mailto:support@nova-labs.dev" class="hover:text-text transition-colors">Support</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Navbar scroll effect + form handler -->
  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.add('bg-surface/80', 'backdrop-blur-lg', 'border-b', 'border-surface-lighter/30');
      } else {
        navbar?.classList.remove('bg-surface/80', 'backdrop-blur-lg', 'border-b', 'border-surface-lighter/30');
      }
    });

  </script>
</Layout>

<style is:global>
  .prose {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: 1.125rem;
  }

  .prose h2 {
    color: var(--color-text);
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .prose h3 {
    color: var(--color-text);
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose p {
    margin-bottom: 1.25rem;
  }

  .prose strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose a {
    color: var(--color-primary-light);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }

  .prose a:hover {
    color: var(--color-accent-light);
  }

  .prose ul, .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose ul {
    list-style-type: disc;
  }

  .prose ol {
    list-style-type: decimal;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text);
  }

  .prose code {
    background: rgba(30, 41, 59, 0.8);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
    color: var(--color-accent-light);
  }

  .prose pre {
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid rgba(51, 65, 85, 0.5);
    margin: 2rem 0;
  }
</style>
