---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "Nova Labs",
      "url": "https://nova-labs.dev",
      "description": "AI-first business building digital products. An experiment by AckNova Automations.",
      "foundingDate": "2026-03-07"
    },
    {
      "@type": "Product",
      "name": "AI OS Blueprint",
      "description": "Build your own AI Operating System with Claude Code. Complete playbook with ready-to-use system, 5 business skills, and case study.",
      "image": "https://nova-labs.dev/og-image.png",
      "brand": { "@type": "Brand", "name": "Nova Labs" },
      "offers": [
        {
          "@type": "Offer",
          "name": "Playbook",
          "price": "47",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": "https://nova-labs.dev",
          "priceValidUntil": "2026-12-31",
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
            "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
            "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": "0", "maxValue": "0", "unitCode": "d" }, "transitTime": { "@type": "QuantitativeValue", "minValue": "0", "maxValue": "0", "unitCode": "d" } }
          },
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "US",
            "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
            "merchantReturnDays": "30",
            "returnMethod": "https://schema.org/ReturnByMail",
            "returnFees": "https://schema.org/FreeReturn"
          }
        },
        {
          "@type": "Offer",
          "name": "Bundle",
          "price": "97",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock",
          "url": "https://nova-labs.dev",
          "priceValidUntil": "2026-12-31",
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
            "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
            "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": "0", "maxValue": "0", "unitCode": "d" }, "transitTime": { "@type": "QuantitativeValue", "minValue": "0", "maxValue": "0", "unitCode": "d" } }
          },
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "US",
            "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
            "merchantReturnDays": "30",
            "returnMethod": "https://schema.org/ReturnByMail",
            "returnFees": "https://schema.org/FreeReturn"
          }
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do I need coding experience?", "acceptedAnswer": { "@type": "Answer", "text": "No. The AI OS Blueprint is designed for non-technical entrepreneurs. You copy, paste, and customize." }},
        { "@type": "Question", "name": "Does this work with ChatGPT?", "acceptedAnswer": { "@type": "Answer", "text": "The system is built specifically for Claude Code by Anthropic. ChatGPT does not support the skills and automation architecture used in AI OS." }},
        { "@type": "Question", "name": "How long does setup take?", "acceptedAnswer": { "@type": "Answer", "text": "Most users have their AI OS running within 1 hour. The playbook includes step-by-step instructions and a clone-ready repository." }}
      ]
    }
  ]
};
---

<Layout
  title="AI OS Blueprint - Build Your Own AI-Powered Business | Nova Labs"
  description="Build your own AI Operating System with Claude Code. No coding required. Complete system set up in 1 hour. By Nova Labs."
  jsonLd={jsonLd}
>
  <!-- ============================================ -->
  <!-- NAV -->
  <!-- ============================================ -->
  <nav class="fixed top-0 left-0 right-0 z-40 transition-all duration-300" id="navbar">
    <div class="section-container flex items-center justify-between py-4">
      <a href="/" class="text-xl font-bold tracking-tight">
        <span class="text-primary-light">Nova</span><span class="text-text-dim">Labs</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/free-chapter" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Free Preview</a>
        <a href="/skills" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Skills</a>
        <a href="/blog" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Blog</a>
        <a href="#pricing" class="btn-primary !py-2.5 !px-5 !text-sm">
          Get the playbook
        </a>
      </div>
    </div>
  </nav>

  <!-- ============================================ -->
  <!-- HERO -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex items-center pt-20 pb-16 overflow-hidden">
    <!-- Mesh grid background (inspired by OG image) -->
    <div class="hero-mesh" aria-hidden="true"></div>

    <!-- Floating orbs -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <!-- Floating particles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <div class="section-container relative z-10 text-center max-w-4xl">
      <div class="hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-light border border-surface-lighter mb-8 text-sm text-text-muted">
        <span class="w-2 h-2 bg-success rounded-full pulse-ring"></span>
        Launch pricing - limited time
      </div>

      <h1 class="text-5xl md:text-7xl font-black leading-tight mb-6 tracking-tight">
        Stop re-explaining your business <span class="gradient-text">to AI every time</span>
      </h1>

      <p class="text-xl md:text-2xl text-text-muted max-w-2xl mx-auto mb-4 leading-relaxed">
        Build an AI system that knows your customers, writes in your voice, and runs your daily operations. Using Claude Code.
      </p>

      <p class="text-lg text-text-dim max-w-xl mx-auto mb-10">
        Complete playbook + ready-to-clone system. Set up in 1 hour. No coding required.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#pricing" class="btn-primary text-lg">
          Get the playbook - $47
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/free-chapter" class="btn-secondary">
          Read 2 chapters free
        </a>
      </div>

      <p class="mt-4 text-sm text-text-dim">400+ visitors this month. Free preview available.</p>

      <div class="mt-6 flex flex-wrap justify-center gap-6 text-sm text-text-dim">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          30-day money-back guarantee
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          One-time payment
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          Instant access
        </span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
      <svg class="w-6 h-6 text-text-dim" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- PROOF BAR -->
  <!-- ============================================ -->
  <section class="py-12 border-y border-surface-lighter/30 bg-surface-light/30 shimmer-line">
    <div class="section-container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="text-3xl font-black gradient-text stat-glow">65+</p>
          <p class="text-text-dim text-sm mt-1">Pages of guidance</p>
        </div>
        <div>
          <p class="text-3xl font-black gradient-text stat-glow">5</p>
          <p class="text-text-dim text-sm mt-1">Ready-to-use skills</p>
        </div>
        <div>
          <p class="text-3xl font-black gradient-text stat-glow">1 hr</p>
          <p class="text-text-dim text-sm mt-1">Setup time</p>
        </div>
        <div>
          <p class="text-3xl font-black gradient-text stat-glow">$0</p>
          <p class="text-text-dim text-sm mt-1">Extra tools needed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHO IS THIS FOR -->
  <!-- ============================================ -->
  <section class="py-24 relative" id="who">
    <div class="section-container max-w-3xl">
      <div class="fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">Built for people who <span class="gradient-text">actually use AI</span></h2>
        <p class="text-text-muted text-center text-lg mb-12">You already know AI is powerful. You just need a system to make it stick.</p>

        <div class="grid md:grid-cols-2 gap-4">
          {[
            { role: 'Solopreneurs & freelancers', desc: 'who want an AI employee without hiring one' },
            { role: 'Small business owners', desc: 'who lose hours on content, email, and admin every week' },
            { role: 'Agency founders', desc: 'who want to deliver more with a smaller team' },
            { role: 'Tech-curious professionals', desc: 'who tried ChatGPT but want something that actually remembers' },
          ].map((item) => (
            <div class="flex items-start gap-4 p-5 glass-card hover:border-primary/30 transition-all">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary/15 flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <div>
                <p class="font-semibold text-text">{item.role}</p>
                <p class="text-text-muted text-sm mt-0.5">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- ============================================ -->
  <!-- PROBLEM -->
  <!-- ============================================ -->
  <section class="py-24 relative" id="problem">
    <div class="section-container max-w-3xl">
      <div class="fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Sound familiar?</h2>

        <div class="space-y-5">
          {[
            'You use ChatGPT or Claude, but every session you start from scratch',
            'You see others talking about "AI OS" but have no idea where to begin',
            'You lose hours on content writing, emails, planning and admin',
            'You want to automate but don\'t have the budget for expensive agencies',
            'Claude Code sounds interesting, but "too technical" for you',
          ].map((item) => (
            <div class="flex items-start gap-4 p-5 rounded-xl bg-surface-light/50 border border-red-500/10 hover:border-red-500/25 transition-colors">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-500/15 flex items-center justify-center mt-0.5">
                <svg class="w-3.5 h-3.5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </span>
              <p class="text-text-muted text-lg">{item}</p>
            </div>
          ))}
        </div>

        <div class="mt-12 p-6 rounded-xl border border-primary/20 bg-primary/5 text-center">
          <p class="text-xl md:text-2xl font-semibold">
            You don't need an AI tool.<br />
            <span class="gradient-text">You need an AI system.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SOLUTION -->
  <!-- ============================================ -->
  <section class="py-24 relative">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-1/2 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="section-container max-w-3xl relative z-10">
      <div class="fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-center">
          What if your AI <span class="gradient-text">actually knew your business</span>?
        </h2>

        <p class="text-text-muted text-center text-lg mb-12">Imagine your AI could:</p>

        <div class="grid gap-4">
          {[
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', text: 'Know your customers and how you write' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', text: 'Plan your day based on your priorities' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', text: 'Create content that sounds like you' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', text: 'Analyze your inbox and highlight what matters' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Remember everything you\'ve ever discussed' },
          ].map((item) => (
            <div class="flex items-center gap-4 p-5 glass-card hover:border-primary/30 transition-all duration-300">
              <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/15 flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                </svg>
              </span>
              <p class="text-lg">{item.text}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <p class="text-xl text-text-muted">
            That's an <strong class="text-text">AI Operating System</strong>. And this playbook shows you how to build one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider" aria-hidden="true"></div>

  <!-- ============================================ -->
  <!-- WHAT YOU GET -->
  <!-- ============================================ -->
  <section class="py-24 relative" id="whats-included">
    <div class="section-container">
      <div class="fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">What you get</h2>
        <p class="text-text-muted text-center text-lg mb-16 max-w-xl mx-auto">
          Everything you need to go from zero to a working AI system.
        </p>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <!-- Playbook -->
          <div class="glass-card glow-border p-8 hover:border-primary/30 transition-all duration-300 group">
            <div class="icon-glow w-14 h-14 rounded-2xl bg-primary/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">The Playbook (65+ pages)</h3>
            <p class="text-text-muted leading-relaxed">
              From concept to working system. Step by step, with diagrams and examples. Written for entrepreneurs, not developers.
            </p>
          </div>

          <!-- Clone-ready repo -->
          <div class="glass-card glow-border p-8 hover:border-primary/30 transition-all duration-300 group">
            <div class="icon-glow-accent w-14 h-14 rounded-2xl bg-accent/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Ready-to-use system</h3>
            <p class="text-text-muted leading-relaxed">
              No blank slate. A fully configured AI OS with 5 business skills, context templates, and memory system. Clone, fill in, and you're running.
            </p>
          </div>

          <!-- 5 Business Skills -->
          <div class="glass-card glow-border p-8 hover:border-primary/30 transition-all duration-300 group">
            <div class="icon-glow-success w-14 h-14 rounded-2xl bg-success/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">5 Business Skills</h3>
            <ul class="text-text-muted space-y-2">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Content writing in your voice
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Daily planning and task management
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Email inbox analysis and prioritization
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Meeting preparation
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-success flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Weekly review and strategy
              </li>
            </ul>
          </div>

          <!-- Case Study -->
          <div class="glass-card glow-border p-8 hover:border-primary/30 transition-all duration-300 group">
            <div class="icon-glow-warning w-14 h-14 rounded-2xl bg-warning/15 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Nova Labs Case Study</h3>
            <p class="text-text-muted leading-relaxed">
              How an AI-run company uses this system daily. No theory - real results.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- COMPARISON -->
  <!-- ============================================ -->
  <section class="py-24 relative">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[150px]"></div>
    </div>

    <div class="section-container max-w-4xl relative z-10">
      <div class="fade-in">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          This isn't a course. <span class="gradient-text">It's a system.</span>
        </h2>
        <p class="text-text-muted text-center mb-12 text-lg">See the difference.</p>

        <div class="glass-card overflow-hidden">
          <div class="grid grid-cols-2 text-sm font-semibold uppercase tracking-wider">
            <div class="p-5 bg-red-500/10 text-red-400 text-center">What you do now</div>
            <div class="p-5 bg-success/10 text-success text-center">With AI OS Blueprint</div>
          </div>

          {[
            ['Re-explain who you are every chat', 'Your AI knows your business, clients, and writing style'],
            ['Hunt for copy-paste prompts', 'Skills that automatically do the right thing'],
            ['Forget what you discussed last week', 'Memory system that remembers everything'],
            ['Hours on content and admin', 'Automated workflows'],
