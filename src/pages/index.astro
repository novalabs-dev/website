  <!-- Navbar scroll effect + form handler -->
  <script>
    const navbar = document.getElementById('navbar');
    const stickyCta = document.getElementById('sticky-cta');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.add('bg-surface/80', 'backdrop-blur-lg', 'border-b', 'border-surface-lighter/30');
      } else {
        navbar?.classList.remove('bg-surface/80', 'backdrop-blur-lg', 'border-b', 'border-surface-lighter/30');
      }
      // Show sticky CTA after scrolling past hero
      if (window.scrollY > 600) {
        stickyCta?.classList.remove('translate-y-full');
      } else {
        stickyCta?.classList.add('translate-y-full');
      }
    });

    // Google Ads checkout click tracking (backup voor conversion tracking)
    document.querySelectorAll('.checkout-link').forEach(link => {
      link.addEventListener('click', () => {
        const value = parseFloat((link as HTMLElement).dataset.value || '47');
        const product = (link as HTMLElement).dataset.product || 'playbook';
        if (typeof gtag === 'function') {
          gtag('event', 'conversion', {
            'send_to': 'AW-18013644812/8ZpPCI7G-4ccEIzQyY1D',
            'value': value,
            'currency': 'USD'
          });
          gtag('event', 'begin_checkout', {
            'currency': 'USD',
            'value': value,
            'items': [{ 'item_name': 'AI OS Blueprint - ' + product, 'price': value }]
          });
        }
      });
    });

    // ROI Calculator
    const calcHours = document.getElementById('calc-hours') as HTMLInputElement;
    const calcRate = document.getElementById('calc-rate') as HTMLInputElement;
    const calcHoursDisplay = document.getElementById('calc-hours-display');
    const calcRateDisplay = document.getElementById('calc-rate-display');
    const calcSavedHours = document.getElementById('calc-saved-hours');
    const calcSavedWeek = document.getElementById('calc-saved-week');
    const calcSavedYear = document.getElementById('calc-saved-year');
    const calcRoi = document.getElementById('calc-roi');
    const calcPayback = document.getElementById('calc-payback');

    function updateCalculator() {
      const hours = parseInt(calcHours?.value || '10');
      const rate = parseInt(calcRate?.value || '50');
      const savedHrs = Math.round(hours * 0.5);
      const savedWeek = savedHrs * rate;
      const savedYear = savedWeek * 52;
      const savedMonth = savedWeek * 4.33;
      const roi = Math.round(((savedMonth - 47) / 47) * 100);
      const paybackHours = 47 / rate;

      if (calcHoursDisplay) calcHoursDisplay.textContent = String(hours);
      if (calcRateDisplay) calcRateDisplay.textContent = String(rate);
      if (calcSavedHours) calcSavedHours.textContent = String(savedHrs);
      if (calcSavedWeek) calcSavedWeek.textContent = '$' + savedWeek.toLocaleString();
      if (calcSavedYear) {
        const yearK = savedYear >= 1000 ? '$' + Math.round(savedYear / 1000) + 'k' : '$' + savedYear;
        calcSavedYear.textContent = yearK;
      }
      if (calcRoi) calcRoi.textContent = roi.toLocaleString() + '%';
      if (calcPayback) {
        let paybackText: string;
        if (paybackHours < 1) {
          paybackText = 'under 1 hour';
        } else if (paybackHours < 2) {
          paybackText = 'about 1 hour';
        } else {
          paybackText = Math.round(paybackHours) + ' hours';
        }
        calcPayback.innerHTML = 'The $47 playbook pays for itself in <strong class="text-primary-light">' + paybackText + '</strong> of saved time.';
      }

      // GA4 tracking on interaction
      if (typeof gtag === 'function') {
        gtag('event', 'calculator_interaction', {
          'hours_per_week': hours,
          'hourly_rate': rate,
          'estimated_roi': roi
        });
      }
    }

    calcHours?.addEventListener('input', updateCalculator);
    calcRate?.addEventListener('input', updateCalculator);
    updateCalculator();

    // Free chapter click tracking
    document.querySelectorAll('a[href="/free-chapter"]').forEach(link => {
      link.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'view_item', {
            'items': [{ 'item_name': 'AI OS Blueprint - Free Preview', 'price': 0 }]
          });
        }
      });
    });
  </script>
