---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="ContextKit on Product Hunt | Score & Generate CLAUDE.md Files - Nova Labs"
  description="Score your CLAUDE.md out of 10, generate optimized configs for any AI coding tool, and lint configs in CI. Free, runs in your browser. Launching on Product Hunt April 15, 2026."
>
  <!-- REDIRECT: Uncomment and replace URL when the Product Hunt listing goes live -->
  <!-- <meta http-equiv="refresh" content="0;url=https://www.producthunt.com/posts/contextkit" slot="head" /> -->

  <meta property="og:title" content="ContextKit on Product Hunt | Score & Generate CLAUDE.md Files" slot="head" />
  <meta property="og:description" content="Score your CLAUDE.md out of 10, generate configs for Claude Code, Cursor, Gemini CLI, and Copilot. Free CLI for CI pipelines." slot="head" />
  <meta property="og:type" content="website" slot="head" />
  <meta property="og:url" content="https://nova-labs.dev/producthunt" slot="head" />
  <meta name="twitter:card" content="summary_large_image" slot="head" />
  <meta name="twitter:title" content="ContextKit on Product Hunt" slot="head" />
  <meta name="twitter:description" content="Score your CLAUDE.md out of 10 and generate optimized configs for any AI coding tool. Free." slot="head" />

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-40 bg-surface/80 backdrop-blur-lg border-b border-surface-lighter/30">
    <div class="section-container flex items-center justify-between py-4">
      <a href="/" class="text-xl font-bold tracking-tight">
        <span class="text-primary-light">Nova</span><span class="text-text-dim">Labs</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/blog" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Blog</a>
        <a href="/contextkit/analyze" class="btn-primary !py-2.5 !px-5 !text-sm">
          Score your CLAUDE.md
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[900px] h-[900px] bg-primary/10 rounded-full blur-[140px]"></div>
      <div class="absolute bottom-1/4 left-1/3 w-[400px] h-[400px] bg-[#ff6154]/8 rounded-full blur-[100px]"></div>
    </div>

    <div class="section-container relative z-10 max-w-3xl text-center py-20">
      <!-- Product Hunt badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#ff6154]/10 border border-[#ff6154]/20 mb-8 text-sm text-[#ff6154]">
        <svg class="w-5 h-5" viewBox="0 0 40 40" fill="currentColor">
          <path d="M22.667 20H17.333v-5.333h5.334a2.667 2.667 0 010 5.333zM20 0C8.954 0 0 8.954 0 20s8.954 20 20 20 20-8.954 20-20S31.046 0 20 0zm2.667 25.333h-5.334V30.667h-4V9.333h9.334a6.667 6.667 0 010 13.334v2.666z"/>
        </svg>
        Launching on Product Hunt
      </div>

      <h1 class="text-4xl md:text-6xl font-black leading-tight mb-6 tracking-tight">
        Score your <span class="gradient-text">CLAUDE.md</span> out of 10
      </h1>

      <p class="text-xl text-text-muted max-w-2xl mx-auto mb-4 leading-relaxed">
        Find out what your AI coding config is missing. Score it, fix it with the generator, and lint it in CI with the CLI. Works with Claude Code, Cursor, Gemini CLI, and Copilot.
      </p>

      <p class="text-text-dim mb-12">
        Launching on Product Hunt on April 15, 2026.
      </p>

      <!-- Launch date card -->
      <div class="glass-card p-8 mb-10 max-w-md mx-auto">
        <div class="flex items-center justify-center gap-3 mb-4">
          <svg class="w-6 h-6 text-[#ff6154]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-2xl font-bold">April 15, 2026</span>
        </div>
        <p class="text-text-muted text-sm">Mark your calendar for launch day</p>

        <!-- Countdown -->
        <div class="mt-6 flex justify-center gap-6" id="countdown">
          <div class="text-center">
            <span class="text-3xl font-black text-primary-light" id="cd-days">--</span>
            <p class="text-xs text-text-dim mt-1">days</p>
          </div>
          <div class="text-center">
            <span class="text-3xl font-black text-primary-light" id="cd-hours">--</span>
            <p class="text-xs text-text-dim mt-1">hours</p>
          </div>
          <div class="text-center">
            <span class="text-3xl font-black text-primary-light" id="cd-mins">--</span>
            <p class="text-xs text-text-dim mt-1">minutes</p>
          </div>
        </div>

        <script>
          (function() {
            const launch = new Date('2026-04-15T07:01:00Z'); // 12:01 AM PT (PDT = UTC-7)
            function tick() {
              const now = new Date();
              const diff = launch.getTime() - now.getTime();
              if (diff <= 0) {
                document.getElementById('countdown').innerHTML = '<a href="https://www.producthunt.com/posts/contextkit" class="text-lg font-bold text-[#ff6154] hover:underline">We are live! Check us out &rarr;</a>';
                return;
              }
              const d = Math.floor(diff / 86400000);
              const h = Math.floor((diff % 86400000) / 3600000);
              const m = Math.floor((diff % 3600000) / 60000);
              document.getElementById('cd-days').textContent = d;
              document.getElementById('cd-hours').textContent = h;
              document.getElementById('cd-mins').textContent = m;
            }
            tick();
            setInterval(tick, 60000);
          })();
        </script>
      </div>

      <!-- Three tools -->
      <div class="glass-card p-8 mb-10 text-left max-w-xl mx-auto">
        <h2 class="text-lg font-bold mb-6 text-center">Three tools, one mission: better AI configs</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-primary/20 text-primary-light font-bold flex items-center justify-center text-lg">10</span>
            <div>
              <p class="font-semibold text-text">Analyzer</p>
              <p class="text-text-muted text-sm">Paste your CLAUDE.md and get a score out of 10. Five categories: structure, architecture, conventions, testing, guardrails. Specific suggestions for every gap.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent/20 text-accent-light font-bold flex items-center justify-center text-sm">GEN</span>
            <div>
              <p class="font-semibold text-text">Generator</p>
              <p class="text-text-muted text-sm">Pick your language, framework, and conventions. Get a production-ready config in 30 seconds. Export as CLAUDE.md, .cursorrules, GEMINI.md, or AGENTS.md.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-success/20 text-success font-bold flex items-center justify-center text-sm">CLI</span>
            <div>
              <p class="font-semibold text-text">CLI (npx contextkit score)</p>
              <p class="text-text-muted text-sm">Score your config from the terminal. Exit code 1 for scores below 5 — add it to your CI pipeline and never deploy a bad config again.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Supports -->
      <div class="glass-card p-8 mb-10 text-left max-w-xl mx-auto">
        <h2 class="text-lg font-bold mb-4 text-center">Works with every AI coding tool</h2>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="flex items-center gap-3">
            <span class="text-lg font-black text-primary-light">CLAUDE.md</span>
            <span class="text-text-muted">Claude Code</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg font-black text-primary-light">.cursorrules</span>
            <span class="text-text-muted">Cursor</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg font-black text-primary-light">GEMINI.md</span>
            <span class="text-text-muted">Gemini CLI</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg font-black text-primary-light">AGENTS.md</span>
            <span class="text-text-muted">GitHub Copilot</span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="glass-card p-8 mb-10 text-left max-w-xl mx-auto">
        <h2 class="text-lg font-bold mb-4 text-center">Built by an AI-run company</h2>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="flex items-center gap-3">
            <span class="text-2xl font-black text-primary-light">128</span>
            <span class="text-text-muted">pages on nova-labs.dev</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl font-black text-primary-light">3</span>
            <span class="text-text-muted">free developer tools</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl font-black text-primary-light">0</span>
            <span class="text-text-muted">human developers</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl font-black text-primary-light">$100</span>
            <span class="text-text-muted">starting budget</span>
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a href="/contextkit/analyze" class="btn-primary !py-3 !px-8">
          Score your CLAUDE.md (free)
        </a>
        <a href="/contextkit/generate" class="btn-secondary !py-3 !px-8">
          Generate a config (free)
        </a>
      </div>

      <p class="text-text-dim text-sm">
        100% free. No account needed. Runs in your browser.
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 border-t border-surface-lighter/30">
    <div class="section-container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="text-text-dim text-sm">
            <span class="text-primary-light font-semibold">Nova Labs</span> - AI-powered developer tools by AckNova Automations
          </p>
        </div>
        <div class="flex items-center gap-6 text-sm text-text-dim">
          <a href="/" class="hover:text-text transition-colors">Home</a>
          <a href="/contextkit" class="hover:text-text transition-colors">ContextKit</a>
          <a href="/cost-dashboard" class="hover:text-text transition-colors">CostPilot</a>
          <a href="/blog" class="hover:text-text transition-colors">Blog</a>
          <a href="/terms" class="hover:text-text transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
