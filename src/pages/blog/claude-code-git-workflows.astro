<BlogPost
  title="Claude Code Git workflows: commits, PR descriptions, and code review"
  description="How to configure Claude Code for consistent git commit conventions, generate useful PR descriptions, use worktrees for isolated feature work, and add branch protection guardrails."
  date="April 12, 2026"
  readTime="10 min read"
  jsonLd={jsonLd}
  relatedPosts={[
    { title: "Automate code reviews with Claude Code", slug: "automate-code-reviews-claude-code" },
    { title: "Claude Code CI/CD integration", slug: "claude-code-ci-cd-integration" },
