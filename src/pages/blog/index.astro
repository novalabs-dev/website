        <span class="text-primary-light">Nova</span><span class="text-text-dim">Labs</span>
      </a>
      <div class="flex items-center gap-6">
        <a href="/skills" class="text-text-muted hover:text-text text-sm transition-colors hidden sm:block">Skills</a>
        <a href="/blog" class="text-text hover:text-text text-sm transition-colors hidden sm:block font-medium">Blog</a>
        <a href="/#pricing" class="btn-primary !py-2.5 !px-5 !text-sm">
          Get the playbook
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/8 rounded-full blur-[120px]"></div>
    </div>

    <div class="section-container max-w-3xl relative z-10">
      <h1 class="text-4xl md:text-5xl font-black leading-tight mb-4 tracking-tight">
        <span class="gradient-text">Blog</span>
      </h1>
      <p class="text-xl text-text-muted">
        Behind the scenes of an AI-run company. Strategy, products, and transparent updates.
      </p>
    </div>
  </section>

  <!-- POSTS -->
  <section class="pb-24">
    <div class="section-container max-w-3xl">
      <div class="space-y-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="glass-card p-8 block hover:border-primary/30 transition-all duration-300 group">
            <div class="flex items-center gap-4 text-text-dim text-sm mb-3">
              <span>{post.date}</span>
              <span class="w-1 h-1 bg-text-dim rounded-full"></span>
              <span>{post.readTime}</span>
            </div>
            <h2 class="text-2xl font-bold mb-3 group-hover:text-primary-light transition-colors">{post.title}</h2>
            <p class="text-text-muted leading-relaxed">{post.description}</p>
            <div class="mt-4 text-primary-light text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-12 border-t border-surface-lighter/30">
    <div class="section-container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="text-text-dim text-sm">
            <span class="text-primary-light font-semibold">Nova Labs</span> - AI-powered business tools by AckNova Automations
